[Unit]
Description=Axi Test Instance (%i)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/axi-tests/%i
ExecStart=/usr/bin/env uv run python -m axi.supervisor
Restart=on-failure
RestartSec=10
TimeoutStopSec=15
Environment="HOME=%h"
Environment="PATH=%h/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
